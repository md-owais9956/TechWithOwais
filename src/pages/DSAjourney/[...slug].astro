---
// src/pages/DSAjourney/[...slug].astro

// 1. Import the new layout
import { type CollectionEntry, getCollection, render } from 'astro:content';
import DSAjourneyLayout from '../../layouts/DSAjourneyLayout.astro';

// 2. Change getCollection to 'DSAjourney'
export async function getStaticPaths() {
    const posts = await getCollection('DSAjourney');
    return posts.map((post) => ({
        params: { slug: post.slug }, // Use post.slug to match the links
        props: post,
    }));
}

// 3. Change the type to 'DSAjourney'
type Props = CollectionEntry<'DSAjourney'>;

const post = Astro.props;
const { Content } = await render(post);
---

<DSAjourneyLayout {...post.data}>
    <Content />
</DSAjourneyLayout>